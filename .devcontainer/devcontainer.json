{
  "name": "ServiceNow MCP Server",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-python.python",
        "ms-python.pylint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "SNOW_INSTANCE_URL": "${localEnv:SNOW_INSTANCE_URL}",
    "SNOW_USERNAME": "${localEnv:SNOW_USERNAME}",
    "SNOW_PASSWORD": "${localEnv:SNOW_PASSWORD}"
  }
}